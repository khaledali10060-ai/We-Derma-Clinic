{
  "entities": {
    "Appointment": {
      "title": "Appointment",
      "description": "A booking request from a client.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Client's full name." },
        "phone": { "type": "string", "description": "Client's phone number." },
        "email": { "type": "string", "format": "email", "description": "Client's email address." },
        "service": { "type": "string", "description": "The requested medical service." },
        "dateTime": { "type": "string", "format": "date-time", "description": "Preferred date and time for the appointment." },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"], "description": "Current status of the appointment." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the request was created." }
      },
      "required": ["name", "phone", "service", "dateTime", "status", "createdAt"]
    }
  },
  "firestore": {
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Collection of all appointment bookings."
    }
  }
}
